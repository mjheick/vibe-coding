10 PRINT "Primes 0-101 where ((2*x)-1) % 7 = 4:"
20 PRINT
30 FOR X = 0 TO 101
40   GOSUB 200
50   IF P = 0 THEN 90
60   V = (2 * X) - 1
70   R = V - INT(V / 7) * 7
80   IF R = 4 THEN PRINT X
90 NEXT X
100 END
200 REM --- IS PRIME ---
210 P = 0
220 IF X < 2 THEN RETURN
230 IF X = 2 OR X = 3 THEN P = 1 : RETURN
240 IF X MOD 2 = 0 THEN RETURN
250 IF X MOD 3 = 0 THEN RETURN
260 I = 5
270 IF I * I > X THEN P = 1 : RETURN
280 IF X MOD I = 0 THEN RETURN
290 IF X MOD (I + 2) = 0 THEN RETURN
300 I = I + 6
310 GOTO 270
